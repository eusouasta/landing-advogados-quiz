{
  "version": 2,
  "name": "landing-advogados-quiz",
  "framework": null,
  "rewrites": [
    {
      "source": "/assets/css/(.*)",
      "destination": "/assets/css/$1"
    },
    {
      "source": "/assets/js/(.*)",
      "destination": "/assets/js/$1"
    },
    {
      "source": "/assets/images/(.*)",
      "destination": "/assets/images/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ],
  "github": {
    "enabled": true,
    "autoAlias": true
  }
}
